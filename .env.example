# Copy to .env (gitignored) for local dev. In CI these come from GitHub
# repo Settings → Secrets and variables → Actions.

# Supabase project URL — same value as virtual-desk's NEXT_PUBLIC_SUPABASE_URL.
SUPABASE_URL=

# Supabase service-role key. Bypasses RLS; never paste this into a public
# Vercel/Next.js env. Find it at: Supabase Dashboard → Project Settings → API.
SUPABASE_SERVICE_KEY=

# Google AI Studio key for Gemini Flash. Recommended: create a separate key
# scoped to this worker so revoking it doesn't affect other projects.
GEMINI_API_KEY=
